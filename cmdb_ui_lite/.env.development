# CMDB Lite 环境配置文件
# 用于区分不同环境的配置

# 环境名称: development | production | solo
ENV_NAME=development

# API配置
API_BASE_URL=http://localhost:8000
API_TIMEOUT=10000

# 后端服务端口
BACKEND_PORT=8000

# 前端服务端口
# - SOLO云端环境: 3000 (配合API代理)
# - 本地开发环境: 3001 (热重载模式)
FRONTEND_PORT=3000

# 是否启用API代理
# - SOLO云端环境: true
# - 本地开发环境: false
ENABLE_API_PROXY=false

# 是否启用调试模式
DEBUG_MODE=true

# 日志配置
LOG_LEVEL=info
